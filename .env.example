# Site URL (used for SEO meta tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://snappull.com

# Google AdSense (optional)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# REQUIRED: RapidAPI key for video downloads
# ============================================
# 1. Sign up free at https://rapidapi.com/
# 2. Subscribe to "Social Download All In One" API (free tier):
#    https://rapidapi.com/nguyenmanhict-MuTUtGWD7K/api/social-download-all-in-one
# 3. Copy your API key from the dashboard
RAPIDAPI_KEY=your_key_here

# Optional: Self-hosted Cobalt instance URL (fallback)
# COBALT_API_URL=https://your-cobalt-instance.com
